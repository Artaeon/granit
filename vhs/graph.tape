Output assets/graph.gif

Set Shell bash
Set Width 1200
Set Height 600
Set FontSize 16
Set Padding 20
Set TypingSpeed 50ms

Sleep 500ms
Type "./granit example-vault"
Enter
Sleep 3s

# Open graph view
Ctrl+G
Sleep 2s

# Navigate through nodes
Type "j"
Sleep 500ms
Type "j"
Sleep 500ms
Type "j"
Sleep 500ms
Type "j"
Sleep 500ms
Type "j"
Sleep 500ms
Type "k"
Sleep 500ms
Type "k"
Sleep 500ms

Sleep 3s

# Close graph
Escape
Sleep 1s
