Output assets/command-palette.gif

Set Shell bash
Set Width 1200
Set Height 600
Set FontSize 16
Set Padding 20
Set TypingSpeed 80ms

Sleep 500ms
Type "./granit example-vault"
Enter
Sleep 3s

# Open command palette
Ctrl+X
Sleep 1500ms

# Search for "graph"
Type "graph"
Sleep 1500ms

# Clear and search "daily"
Ctrl+U
Sleep 500ms
Type "daily"
Sleep 1500ms

# Clear and search "theme"
Ctrl+U
Sleep 500ms
Type "export"
Sleep 1500ms

# Close palette
Escape
Sleep 1500ms
